# API Keys (optional - for Tier 2 sources)
IEEE_API_KEY=
SPRINGER_API_KEY=

# Semantic Scholar (optional — higher rate limits with a key)
S2_API_KEY=

# LLM Configuration
OLLAMA_BASE_URL=http://localhost:11434
LLM_DEFAULT_MODEL=qwen3.5-reasoning

# Database paths (defaults are fine for most users)
DB_PATH=papers.db
LIBRARY_DB_PATH=local_library.db
CACHE_DIR=.cache

# Backend
API_HOST=127.0.0.1
API_PORT=8000
